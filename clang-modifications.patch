+
+SourceLocation SourceManager::getPreExpansionLoc(SourceLocation Loc) const {
+  if (Loc.isMacroID()) {
+    FileID FID = getFileID(Loc);
+    unsigned Offset = getFileOffset(Loc);
+    
+    // First check FileID map
+    auto FileIDIt = FileIDToOriginalLocMap.find(FID);
+    if (FileIDIt != FileIDToOriginalLocMap.end()) {
+      // llvm::errs() << "LOOKUP_FILEID: FID=" << FID.getHashValue() << " FOUND!\n";
+      return FileIDIt->second;
+    }
+    
+    // // Next check (FileID, Offset) map
+    // llvm::errs() << "LOOKUP: FID=" << FID.getHashValue() 
+    //              << " Offset=" << Offset << "\n";
+    
+    auto It = ExpansionToOriginalMap.find({FID, Offset});
+    if (It != ExpansionToOriginalMap.end()) {
+      // llvm::errs() << "LOOKUP: FOUND!\n";
+      return It->second;
+    }
+    // else {
+    //   llvm::errs() << "LOOKUP: NOT FOUND! Map size=" << ExpansionToOriginalMap.size() << "\n";
+    // }
+  }
+  
+  return Loc;
+}
+
+SourceLocation SourceManager::getOriginalLoc(SourceLocation Loc) const {
+  int depth = 0;
+  const int MAX_DEPTH = 100; // Prevent infinite loop
+  
+  while (Loc.isMacroID() && depth < MAX_DEPTH) {
+    SourceLocation PreLoc = getPreExpansionLoc(Loc);
+    if (PreLoc.getRawEncoding() == Loc.getRawEncoding()) {
+      break; // Cannot trace further
+    }
+    Loc = PreLoc;
+    depth++;
+  }
+  
+  return Loc;
+}
+
+void SourceManager::recordMacroExpansion(SourceLocation ExpandedLoc, 
+                                        SourceLocation OriginalLoc) {
+  if (ExpandedLoc.isInvalid() || OriginalLoc.isInvalid()) {
+    return;
+  }
+
+  FileID FID = getFileID(ExpandedLoc);
+  unsigned Offset = getFileOffset(ExpandedLoc);
+
+  // Added debug output
+  // llvm::errs() << "RECORD: FID=" << FID.getHashValue() 
+  //              << " Offset=" << Offset 
+  //              << " isMacroID=" << ExpandedLoc.isMacroID() << "\n";
+
+  // Record in map
+  ExpansionToOriginalMap[{FID, Offset}] = OriginalLoc;
+}
+
+// End of addition
+
+void SourceManager::recordFileIDMapping(FileID MacroFID, SourceLocation OriginalLoc) {
+  if (MacroFID.isInvalid() || OriginalLoc.isInvalid()) {
+    return;
+  }
+  
+  FileIDToOriginalLocMap[MacroFID] = OriginalLoc;
+  
+  // llvm::errs() << "RECORD_FILEID: FID=" << MacroFID.getHashValue() 
+  //              << " -> Loc=" << OriginalLoc.getRawEncoding() << "\n";
+}
+
+
+std::string SourceManager::getMacroTokenText(SourceLocation Loc) const {
+  if (Loc.isInvalid() || !Loc.isMacroID()) {
+    //llvm::errs() << "getMacroTokenText: Invalid or not MacroID\n";
+    return "";
+  }
+  
+  FileID FID = getFileID(Loc);
+  unsigned Offset = getFileOffset(Loc);
+  
+  // llvm::errs() << "getMacroTokenText: Searching FID=" << FID.getHashValue() 
+  //              << " Offset=" << Offset << "\n";
+  
+  auto FIDIt = MacroTokenTextMap.find(FID);
+  if (FIDIt != MacroTokenTextMap.end()) {
+    auto OffsetIt = FIDIt->second.find(Offset);
+    if (OffsetIt != FIDIt->second.end()) {
+      // llvm::errs() << "getMacroTokenText: FOUND=" << OffsetIt->second << "\n";
+      return OffsetIt->second;
+    }
+  }
+  
+  // llvm::errs() << "getMacroTokenText: NOT FOUND (Map has " 
+  //              << MacroTokenTextMap.size() << " FileIDs)\n";
+  return "";
+}
+
+// ended
